@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@{
    var isAdmin = User.IsInRole("Admin");
    var isUser = User.IsInRole("User");
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - GearUp</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="~/css/styles.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css">
    <style>
        .navbar-brand {
            font-size: 30px;
            font-weight: bold;
            font-style: italic;
        }

        .dropdown-menu {
            background-color: #212529;
            width: 100px !important;
            border-radius: 8px;
            padding: 5px 0;
        }

        .dropdown-item {
            font-family: sans-serif;
            font-size: 15px;
            padding-top: 10px;
            color: #D3D3D3;
            margin-bottom: 5px;
        }

        body {
            background-color: #000000 !important;
            color: #ffffff;
        }
    </style>
</head>
<body class="d-flex flex-column min-vh-100">

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">GearUp</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto d-flex align-items-center">



                    @if (isUser)
                    {
                      
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="User_Index">Home</a>
                        </li>
                       
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" onclick="toggleDropdown(event)">Cities</a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="City" asp-action="Lahore">Lahore</a></li>
                                <li><a class="dropdown-item" asp-controller="City" asp-action="Islamabad">Islamabad</a></li>
                                <li><a class="dropdown-item" asp-controller="City" asp-action="Karachi">Karachi</a></li>
                            </ul>
                        </li>

                        
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" onclick="toggleDropdown(event)">Vehicles</a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="Vehicle" asp-action="Luxury">Luxury Cars</a></li>
                                <li><a class="dropdown-item" asp-controller="Vehicle" asp-action="Economy">Economy Cars</a></li>
                                <li><a class="dropdown-item" asp-controller="Vehicle" asp-action="Sports">Sports Cars</a></li>
                                <li><a class="dropdown-item" asp-controller="Vehicle" asp-action="Coaster">Coasters</a></li>
                            </ul>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="AboutUs">About Us</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="ContactUs">Contact Us</a>
                        </li>
                    }

                    @if (isAdmin)
                    {
                        
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Admin_Index">Home</a>
                        </li>
                       
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" onclick="toggleDropdown(event)">Operations</a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="Vehicle" asp-action="Add">Add</a></li>
                                <li><a class="dropdown-item" asp-controller="Vehicle" asp-action="Update">Update</a></li>
                                <li><a class="dropdown-item" asp-controller="Vehicle" asp-action="Delete">Delete</a></li>
                                <li><a class="dropdown-item" asp-controller="Vehicle" asp-action="AllVehicles">All Vehicles</a></li>
                            </ul>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Booking" asp-action="ShowBookings">Bookings</a>
                        </li>
                    }

                   
                    <li class="nav-item dropdown">
                        <a class="nav-link d-flex align-items-center" href="#" data-bs-toggle="dropdown">
                            <img src="~/pics/user.jpg" alt="User" class="rounded-circle border border-light" width="45" height="45" style="object-fit: cover;">
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end shadow rounded-3 p-3">
                            <li>
                                <a class="dropdown-item d-flex align-items-center" asp-area="Identity" asp-page="/Account/Updateuser">
                                    <i class="bi bi-pencil-square me-2"></i> Account
                                </a>
                            </li>
                            @if (isUser)
                            {
                                <li>
                                    <a class="dropdown-item d-flex align-items-center" href="@Url.Action("Index", "Cart")">
                                        <i class="bi bi-cart-fill me-2"></i> Cart
                                    </a>
                                </li>
                            }
                            <li><hr class="dropdown-divider" /></li>
                            <li class="mt-1">
                                <form method="post" asp-area="Identity" asp-page="/Account/Logout"
                                      asp-route-returnUrl="/Identity/Account/Login">
                                    <button type="submit" class="dropdown-item d-flex align-items-center text-danger border-0 bg-transparent">
                                        <i class="bi bi-box-arrow-right me-2"></i> Log Out
                                    </button>
                                </form>

                            </li>

                        </ul>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <main class="flex-fill">
        <div class="container mt-4 mb-5">
            @RenderBody()
        </div>
    </main>

    <footer class="bg-dark text-white text-center py-3 mt-auto">
        <p>&copy; 2025 GearUp - Rent A Car. All Rights Reserved.</p>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function toggleDropdown(event) {
            event.preventDefault();
            let dropdownMenu = event.target.nextElementSibling;
            if (dropdownMenu.classList.contains("show")) {
                bootstrap.Dropdown.getInstance(event.target).hide();
            } else {
                new bootstrap.Dropdown(event.target).show();
            }
        }
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>


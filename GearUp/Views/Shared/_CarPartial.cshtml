@model GearUp.Models.Vehicle

<div class="col-md-6 col-lg-4 mb-4 car-card" data-category="@Model.City @Model.Category">
    <div class="card h-100 shadow-sm" style="background-color: #212529; color: white; border-radius: 0;">
        <a asp-action="Details" asp-route-id="@Model.VehicleID" style="text-decoration: none; color: inherit;">
            <img src="~/pics/@Model.ImagePath"
                 class="card-img-top"
                 alt="@Model.Model"
                 style="height: 200px; object-fit: cover; width: 100%; border-radius: 0;
                        padding: 15px 15px 5px 15px; margin-bottom: 0;">
        </a>
        <div class="card-body d-flex flex-column">
            <a asp-action="Details" asp-route-id="@Model.VehicleID" style="text-decoration: none; color: inherit;">
                <h5 class="card-title">@Model.Brand @Model.Model</h5>
            </a>
            <p class="card-text">
                <strong>Status:</strong>
                @if (Model.AvailabilityStatus)
                {
                    <span class="text-success">Available</span>
                }
                else
                {
                    <span class="text-danger">Booked</span>
                }
                <br />
                <strong>Rent Per Day:</strong> $@Model.RentPerDay <br />
            </p>
            <div class="mt-auto">
                <form asp-action="AddToCart" asp-controller="Cart" method="post">
                    <input type="hidden" name="vehicleId" value="@Model.VehicleID" />
                    <button type="submit" class="btn w-100" style="background-color: lightgray; color: black;">Add to Cart</button>
                </form>
            </div>
        </div>
    </div>
</div>

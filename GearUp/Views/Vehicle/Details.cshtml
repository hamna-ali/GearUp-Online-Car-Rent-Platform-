@model GearUp.Models.Vehicle
@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

@{
    ViewData["Title"] = "Vehicle Details";
    var isAdmin = User.IsInRole("Admin");
    var isUser = User.IsInRole("User");
    var returnMessage = TempData["ReturnMessage"] as string;
    var returnSuccess = TempData["ReturnSuccess"] as bool?;
}
@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var popup = document.getElementById('return-popup');
            if (popup) {
                popup.style.display = 'block';
                setTimeout(function () {
                    popup.style.display = 'none';
                }, 2000);
            }
        });

        function confirmDelete() {
            return confirm("Are you sure you want to delete this vehicle?");
        }
    </script>
}

@if (!string.IsNullOrEmpty(returnMessage))
{
    <div id="return-popup" class="position-fixed top-0 start-50 translate-middle-x mt-3 p-3 rounded shadow" style="z-index: 1050; background-color: lightgray; color: black; display: none;">
        @returnMessage
    </div>
}
<div class="container mt-5" style="max-width: 1500px;">
        <!-- Vehicle Image Centered -->
        <div class="text-center mb-4">
            <img src="~/pics/@Model.ImagePath" class="img-fluid rounded shadow" style="max-height: 600px;width:100%; object-fit: cover;" alt="@Model.Model" />
        </div>

    <!-- Vehicle Details -->
    <div class="row justify-content-center">
        <div class="col-md-8">
            <h3 class="mb-3">@Model.Brand @Model.Model</h3>
            <ul class="list-group list-group-flush mb-4 dark-list">
                <li class="list-group-item"><strong>Brand:</strong> @Model.Brand</li>
                <li class="list-group-item"><strong>Model:</strong> @Model.Model</li>
                <li class="list-group-item"><strong>Category:</strong> @Model.Category</li>
                <li class="list-group-item"><strong>Plate Number:</strong> @Model.PlateNumber</li>
                <li class="list-group-item"><strong>City:</strong> @Model.City</li>
                <li class="list-group-item"><strong>Description:</strong> @Model.Description</li>
                <li class="list-group-item"><strong>Rent Per Day:</strong> $@Model.RentPerDay</li>
                <li class="list-group-item">
                    <strong>Status:</strong>
                    @if (Model.AvailabilityStatus)
                    {
                        <span class="text-success">Available</span>
                    }
                    else
                    {
                        <span class="text-danger">Booked</span>
                    }
                </li>
            </ul>


            <!-- Conditional Buttons -->
            @if (isAdmin)
            {
                <div class="d-flex flex-column gap-2 mt-3">
                    <!-- Return Vehicle -->
                    <form asp-action="ReturnVehicle" asp-controller="Vehicle" method="post">
                        <input type="hidden" name="PlateNumber" value="@Model.PlateNumber" />
                        <input type="hidden" name="VehicleID" value="@Model.VehicleID" />
                        <button type="submit" class="btn btn-secondary w-100">Return Vehicle</button>
                    </form>

                    <!-- Update Vehicle -->
                    <a asp-controller="Vehicle" asp-action="Update" asp-route-plateNumber="@Model.PlateNumber" class="btn btn-secondary w-100">
                        Update Vehicle
                    </a>

                    <!-- Delete Vehicle -->
                    <form asp-controller="Vehicle" asp-action="DeleteAdmin" method="post" onsubmit="return confirmDelete();">
                        <input type="hidden" name="PlateNumber" value="@Model.PlateNumber" />
                        <input type="hidden" name="VehicleID" value="@Model.VehicleID" />
                        <button type="submit" class="btn btn-danger w-100">Delete Vehicle</button>
                    </form>
                </div>
            }
            else if (isUser)
            {
                <!-- Add to Cart for Regular User -->
                <form asp-action="AddToCartAsync" asp-controller="Cart" method="post">
                    <input type="hidden" name="vehicleId" value="@Model.VehicleID" />
                    <button type="submit" class="btn w-100 mt-2" style="background-color: lightgray; color: black;">Add to Cart</button>
                </form>
            }
        </div>
    </div>
</div>

<style>
    .dark-list {
        background-color: #212529; /* Bootstrap dark gray */
        color: white;
    }

        .dark-list .list-group-item {
            background-color: #212529;
            color: white;
            border-color: #495057;
        }
</style>

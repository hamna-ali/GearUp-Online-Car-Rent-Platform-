@model GearUp.Models.Vehicle

@{
    ViewData["Title"] = "Add Vehicle";
}

<div class="container">
    <div class="row justify-content-center mt-5">
        <div class="col-md-8">
            <div class="card custom-card">
                <div class="card-header text-center">
                    <h2>Add a New Vehicle</h2>
                </div>
                <div class="card-body">
                    <form asp-action="Add" asp-controller="Vehicle" method="post" enctype="multipart/form-data">
                        <!-- Brand -->
                        <div class="form-group custom-form-group">
                            <label for="Brand">Brand</label>
                            <input type="text" class="form-control" id="Brand" name="Brand" value="@Model.Brand" required />
                        </div>

                        <!-- Model -->
                        <div class="form-group custom-form-group">
                            <label for="Model">Model</label>
                            <input type="text" class="form-control" id="Model" name="Model" value="@Model.Model" required />
                        </div>

                        <!-- Category -->
                        <div class="form-group custom-form-group">
                            <label for="Category">Category</label>
                            <input type="text" class="form-control" id="Category" name="Category" value="@Model.Category" required />
                        </div>

                        <!-- Plate Number -->
                        <div class="form-group custom-form-group">
                            <label for="PlateNumber">Plate Number</label>
                            <input type="text" class="form-control" id="PlateNumber" name="PlateNumber" value="@Model.PlateNumber" required />
                        </div>

                        <!-- Description -->
                        <div class="form-group custom-form-group">
                            <label for="Description">Description</label>
                            <textarea class="form-control" id="Description" name="Description" required>@Model.Description</textarea>
                        </div>

                        <!-- RentPerDay -->
                        <div class="form-group custom-form-group">
                            <label for="RentPerDay">Rent Per Day</label>
                            <input type="number" class="form-control" id="RentPerDay" name="RentPerDay" value="@Model.RentPerDay" min="0" required />
                        </div>

                        <!-- City -->
                        <div class="form-group custom-form-group">
                            <label for="City">City</label>
                            <input type="text" class="form-control" id="City" name="City" value="@Model.City" required />
                        </div>

                        <!-- Image Upload -->
                        <div class="form-group custom-form-group">
                            <label for="Image">Upload Vehicle Image</label>
                            <input type="file" class="form-control" id="Image" name="image" />
                        </div>

                        <button type="submit" class="btn custom-btn w-100">Add Vehicle</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Display Success or Error Message -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success mt-3 text-center" id="successMessage">
            @TempData["SuccessMessage"]
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger mt-3 text-center" id="errorMessage">
            @TempData["ErrorMessage"]
        </div>
    }
</div>

<!-- Script to hide success/error message after 2 seconds -->
@section Scripts {
    <script>
        $(document).ready(function () {
            if ($("#successMessage").length) {
                setTimeout(function () {
                    $("#successMessage").fadeOut();
                }, 2000); // Hide after 2 seconds
            }
            if ($("#errorMessage").length) {
                setTimeout(function () {
                    $("#errorMessage").fadeOut();
                }, 2000); // Hide after 2 seconds
            }
        });
    </script>
}

<style>
    /* Custom Styling */
    .container {
        width: 100%; /* Keep the container width same as before */
    }

    .custom-card {
        background-color: #333; /* Dark grey container */
        color: white;
    }

    .custom-form-group {
        margin-left: 20px; /* Increase left margin */
        margin-right: 20px; /* Increase right margin */
    }

    .form-control {
        background-color: #f0f0f0; /* Light grey fields */
        color: #333;
    }

    .custom-btn {
        background-color: #f0f0f0; /* Light grey button */
        color: black;
        border: none;
    }

        .custom-btn:hover {
            background-color: #333; /* Dark grey button on hover */
            color: white;
        }

    .alert {
        background-color: #f0f0f0; /* Light grey popup */
        color: black;
    }

    body {
        background-color: black; /* Set the background to black */
    }
</style>

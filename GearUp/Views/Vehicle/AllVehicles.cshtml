@model IEnumerable<GearUp.Models.Vehicle>
@{
    ViewData["Title"] = "All Vehicles";
}

<h2 class="text-center mb-4">All Vehicles</h2>

<div class="container">
    <div class="row">
        @foreach (var vehicle in Model)
        {
            <div class="col-md-6 col-lg-4 mb-4">

                <div class="card h-100 shadow-sm" style="background-color: #212529; color: white;border-radius: 0;">
                    <a asp-action="Details" asp-route-id="@vehicle.VehicleID" style="text-decoration: none; color: inherit;">
                        <img src="~/pics/@vehicle.ImagePath"
                             class="card-img-top"
                             alt="@vehicle.Model"
                             style="height: 200px; object-fit: cover; width: 100%; border-radius: 0;
                             padding: 15px 15px 5px 15px; margin-bottom: 0;">

                    </a>
                    <div class="card-body d-flex flex-column">
                        <a asp-action="Details" asp-route-id="@vehicle.VehicleID" style="text-decoration: none; color: inherit;">
                            <h5 class="card-title">@vehicle.Brand @vehicle.Model</h5>
                        </a>
                        <p class="card-text">
                            <strong>Status:</strong>
                            @if (vehicle.AvailabilityStatus)
                            {
                                <span class="text-success">Available</span>
                            }
                            else
                            {
                                <span class="text-danger">Booked</span>
                            }
                            <br />
                            <strong>Rent Per Day:</strong> $@vehicle.RentPerDay <br />
                        </p>
                        <div class="mt-auto">
                            <form asp-action="ReturnVehicle" asp-controller="Vehicle" method="post">
                                <input type="hidden" name="vehicleId" value="@vehicle.VehicleID" />
                                <button type="submit" class="btn w-100" style="background-color: lightgray; color: black;">Returned Vehicle</button>
                            </form>
                        </div>
                    </div> <!-- close card-body -->
                </div> <!-- close card -->
            </div>
        }
    </div>
</div>

@page
@model RegisterModel
@{
    Layout = null;
    ViewData["Title"] = "Register";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        body {
            background: url('/pics/auth.jpg') no-repeat center center/cover;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
        }

        .register-card {
            background: rgba(0, 0, 0, 0.8);
            padding: 30px;
            border-radius: 15px;
            box-shadow: 0 4px 10px rgba(255, 255, 255, 0.2);
            width: 400px;
            color: white;
        }

        .form-control {
            background-color: transparent !important;
            color: white !important;
            border: none;
            border-bottom: 2px solid white;
            font-size: 16px;
            padding: 12px;
            border-radius: 0;
        }

            .form-control::placeholder {
                color: rgba(255, 255, 255, 0.6);
            }

            .form-control:focus {
                background-color: transparent !important;
                color: white !important;
                border-bottom: 2px solid blue;
                box-shadow: none;
                outline: none;
            }

        .btn-register {
            background-color: white;
            color: black;
            font-weight: bold;
            border-radius: 25px;
            padding: 10px;
            width: 100%;
        }

            .btn-register:hover {
                background-color: #ccc;
            }

        a {
            color: white;
            text-decoration: none;
        }

            a:hover {
                text-decoration: underline;
            }

        label {
            color: white;
        }

        .text-danger {
            font-size: 14px;
        }
    </style>
</head>
<body>
    <div class="register-card text-center">
        <h2 class="mb-4">Register</h2>

        @* ASP.NET Identity Form Starts Here *@
        <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

            <div class="mb-3">
                <input asp-for="Input.FullName" class="form-control" placeholder="Enter your name" />
                <span asp-validation-for="Input.FullName" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <input asp-for="Input.Email" class="form-control" placeholder="Enter your email" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <input asp-for="Input.Password" class="form-control" placeholder="Enter your password" />
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <input asp-for="Input.ConfirmPassword" class="form-control" placeholder="Confirm password" />
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <input asp-for="Input.Address" class="form-control" placeholder="Enter your address" />
                <span asp-validation-for="Input.Address" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <input asp-for="Input.Phone" class="form-control" placeholder="03xxxxxxxxx" />
                <span asp-validation-for="Input.Phone" class="text-danger"></span>
            </div>

            <button id="registerSubmit" type="submit" class="btn btn-register">Register</button>

            <div class="mt-3">
                <a href="/Identity/Account/Login">Already have an account? Login</a>
            </div>
        </form>
        @* ASP.NET Identity Form Ends Here *@

    </div>

    <partial name="_ValidationScriptsPartial" />
</body>
</html>
